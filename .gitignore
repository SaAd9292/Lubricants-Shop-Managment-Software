# ============================================================
#  Penguix — .gitignore
# ============================================================

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Build / packaging artifacts (regenerated by build scripts) ---
build/
dist/
*.egg-info/
*.spec.bak

# --- Installer output (large binaries; ship via Releases, not git) ---
installer/output/

# --- Secrets / licensing private material (NEVER commit) ---
# (re-added when the licensing module returns)
tools/penguix_private.key
*.key
*.pem
.env
.env.*
secrets.*

# --- Runtime data that lives in %APPDATA%\Penguix, never in the repo ---
# (listed defensively in case anyone copies a live data folder in)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
logs/
backups/

# --- OS / editor noise ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
